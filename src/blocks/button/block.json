{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ctx-blocks/button",
	"title": "Button",
	"keywords": ["link", "action", "button"],
	"textdomain": "ctx-blocks",
	"description": "Display a button with a link or a modal",
	"category": "common",
	"attributes": {
		"title": {
			"type": "string",
			"default": ""
		},
		"url": {
			"type": "string",
			"default": ""
		},
		"newTab": {
			"type": "boolean",
			"default": false
		},
		"rel": {
			"type": "string",
			"default": ""
		},
		"icon": {
			"type": "string",
			"default": ""
		},
		"iconRight": {
			"type": "boolean",
			"default": false
		},
		"iconOnly": {
			"type": "boolean",
			"default": false
		},
		"modalFull": {
			"type": "boolean",
			"default": false
		},
		"modalTitle": {
			"type": "string",
			"default": ""
		},
		"action": {
			"type": "string",
			"default": "link"
		},
		"script": {
			"type": "string",
			"default": ""
		},
		"scriptTarget": {
			"type": "string",
			"default": ""
		}
	},
	"parent": ["core/group", "core/navigation", "ctx-blocks/card"],
	"supports": {
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": false
		},
		"spacing": {
			"margin": true
		}
	},
	"styles": [
		{
			"name": "fill",
			"label": "Fill",
			"isDefault": true
		},
		{
			"name": "outline",
			"label": "Outline"
		},
		{
			"name": "link",
			"label": "Link"
		}
	],
	"example": {
		"attributes": {
			"title": "Button",
			"url": "",
			"newTab": false,
			"outline": false,
			"icon": "",
			"iconRight": false,
			"iconOnly": false,
			"modalFull": false,
			"modalTitle": "Modal Title",
			"action": "link"
		}
	},
	"editorStyle": "file:./index.css",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js",
	"render": "file:./render.php"
}
