{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ctx-blocks/conditional",
	"title": "Conditional Content",
	"category": "formatting",
	"keywords": ["date", "time", "country", "user"],
	"textdomain": "ctx-blocks",
	"description": "Show or hide a block under certain conditions",
	"attributes": {
		"fromDate": {
			"type": "string",
			"default": ""
		},
		"toDate": {
			"type": "string",
			"default": ""
		},
		"usersOnly": {
			"type": "boolean",
			"default": false
		},
		"hideWithinDateRange": {
			"type": "boolean",
			"default": false
		},
		"hideOnMobile": {
			"type": "boolean",
			"default": false
		},
		"hideOnDesktop": {
			"type": "boolean",
			"default": false
		}
	},
	"editorStyle": "file:./index.css",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
