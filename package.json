{
	"name": "ctx-blocks",
	"version": "3.1.9",
	"description": "Wordpress block library plugin to replace some standard blocks",
	"author": "kids-team Österreich",
	"prettier": "@wordpress/prettier-config",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"wpPlugin": {
		"name": "ctx-blocks",
		"packageNamespace": "ctx-blocks",
		"handlePrefix": "ctx"
	},
	"scripts": {
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"make-pot": "wp i18n make-pot . languages/ctx-blocks.pot --slug=ctx-blocks --domain=ctx-blocks --exclude=node_modules,src",
		"make-json": "wp i18n make-json languages/ --no-purge",
		"packages-update": "wp-scripts packages-update",
		"release": "wp-github-plugin ctx-blocks.php --tag"
	},
	"dependencies": {
		"@wordpress/icons": "^10.20.0",
		"colord": "^2.9.3",
		"html-react-parser": "^6.1.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@playwright/test": "^1.58.2",
		"@types/wordpress__block-editor": "^15.0.6",
		"@types/wordpress__blocks": "^15.10.0",
		"@types/wordpress__core-data": "^2.4.5",
		"@types/wordpress__data": "^6.0.2",
		"@types/wordpress__editor": "^14.3.1",
		"@wordpress/build": "^0.13.0",
		"@wordpress/interactivity": "^6.40.0",
		"@wordpress/scripts": "^32.0.0",
		"wp-github-plugin": "^1.0.0"
	},
	"browserslist": [
		"> 1%",
		"last 3 versions",
		"not dead",
		"not ie <= 11"
	]
}
